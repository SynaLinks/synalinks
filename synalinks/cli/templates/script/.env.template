# Synalinks reads model credentials from the environment via python-dotenv.
# Copy this file to `.env` and fill in only what your chosen MODEL needs.
#
#   cp .env.template .env
#
# The default MODEL is local Ollama, which needs NO API key — just run
# `ollama serve`. Uncomment a block below only if you switch to a hosted model.

# --- Local Ollama (default) -------------------------------------------------
# Override only if Ollama runs somewhere other than the default localhost.
# OLLAMA_API_BASE=http://localhost:11434

# --- Hosted providers (litellm-style; set the one matching your MODEL) -------
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# MISTRAL_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# --- Synalinks backend (only if you run the hosted Synalinks API) -----------
# SYNALINKS_API_KEY=
# SYNALINKS_API_BASE=http://localhost:8000/api
