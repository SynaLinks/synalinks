# Synalinks reads model credentials from the environment via python-dotenv.
# Copy this file to `.env` and fill in only what your chosen MODEL needs.
#
#   cp .env.template .env
#
# The default MODEL is served by vLLM (OpenAI-compatible). Start it with:
#   vllm serve Qwen/Qwen3-4B          # listens on http://localhost:8000
# The code defaults HOSTED_VLLM_API_BASE to http://localhost:8000/v1 — override
# below if your server is elsewhere. (The /v1 suffix is REQUIRED.)

# --- vLLM endpoint (default) ------------------------------------------------
# HOSTED_VLLM_API_BASE=http://localhost:8000/v1

# --- MLflow tracing (optional) ----------------------------------------------
# Set the tracking URI to enable observability; unset = no tracing. Start one
# with: mlflow server --host 127.0.0.1 --port 5000
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_EXPERIMENT_NAME=synalinks_traces

# --- Local Ollama (alternative, no GPU needed) ------------------------------
# Prefer Ollama? Set MODEL=ollama/mistral:latest in the script and (optionally):
# OLLAMA_API_BASE=http://localhost:11434

# --- Hosted providers (litellm-style; set the one matching your MODEL) -------
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# MISTRAL_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=