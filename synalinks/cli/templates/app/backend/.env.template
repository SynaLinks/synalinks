# Synalinks reads model credentials from the environment via python-dotenv.
# Copy this file to `.env` and fill in only what your chosen MODEL needs.
#
#   cp .env.template .env
#
# The default MODEL is served by vLLM (OpenAI-compatible). docker-compose runs
# vLLM for you; for local dev, start it yourself (see README) and set the base.

# --- Model (baked into the program at build time; rebuild to change) ---------
# MODEL=vllm/Qwen/Qwen3-4B

# --- vLLM endpoint (default) ------------------------------------------------
# Base URL of your vLLM server — MUST include /v1 (litellm appends only
# /chat/completions, and vLLM serves at /v1/chat/completions). In docker-compose
# this points at the `vllm` service automatically. For local dev, run vLLM on a
# non-8000 port so it does not clash with the backend, e.g.
# `vllm serve Qwen/Qwen3-4B --port 8001`.
# HOSTED_VLLM_API_BASE=http://localhost:8001/v1

# --- MLflow tracing (optional) ----------------------------------------------
# Set the tracking URI to enable observability; unset = no tracing.
# docker-compose sets this to the `mlflow` service automatically.
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_EXPERIMENT_NAME=synalinks_traces

# --- Local Ollama (alternative, no GPU needed) ------------------------------
# Prefer Ollama? Set MODEL=ollama/mistral:latest and (optionally) the base:
# OLLAMA_API_BASE=http://localhost:11434

# --- Hosted providers (litellm-style; set the one matching your MODEL) -------
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# MISTRAL_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=