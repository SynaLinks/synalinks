Parent call ID: 0f4edf80-4238-46dc-a71c-cbdf4b900445
Module: Generator
Module Name: tool_calls_generator_recursive_language_model_agent
Module Description: Use a `LanguageModel` to generate a data model from an arbitrary input data model.
Data Model JSON Schema:
[
  {
    "additionalProperties": false,
    "description": "Metadata-only view of the user input shown to the LM.\n\nOnly per-field previews and sizes are surfaced here to keep the prompt small\nwhen the input contains long documents or large collections. The **full**\nuntruncated values are reachable from the agent's code: read them via\n``inputs[field_name]`` (REPL agents) or by reading the JSON file named in\n``inputs_file`` (filesystem agents) — never retype them from the preview.",
    "properties": {
      "fields": {
        "default": [],
        "description": "One entry per top-level input field, each with `name`, `type`, `size` (len of string/list/dict, else null), `preview`, and `truncated` (true when preview omits part of the value). Read the complete value from the `inputs` variable or the `inputs_file`.",
        "items": {
          "additionalProperties": true,
          "type": "object"
        },
        "title": "Fields",
        "type": "array"
      },
      "inputs_file": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "description": "When set, the full untruncated inputs are stored as this JSON file in the sandbox filesystem — read it instead of retyping previews: the `read_file` tool, or in a `run_python_code` snippet `json.loads(pathlib.Path(inputs_file).read_text())` (the sandbox has no `open()`, and `json` provides only `loads` / `dumps`). When null, the full inputs are bound as the `inputs` variable.",
        "title": "Inputs File"
      }
    },
    "title": "InputsSummary",
    "type": "object"
  }
]

